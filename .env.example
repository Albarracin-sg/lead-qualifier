# --- Telegram ---
# Token from @BotFather
TELEGRAM_TOKEN=tu_token_de_botfather

# --- Hugging Face (Chat Completions API) ---
# Token from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=tu_token_de_huggingface
# Model ID for Chat Completions endpoint
HUGGINGFACE_MODEL=deepseek-ai/DeepSeek-V3.2:novita
# API URL (OpenAI-compatible endpoint)
HUGGINGFACE_API_URL=https://router.huggingface.co/v1/chat/completions

# --- Google Sheets ---
# Google Service Account JSON (minified, single line)
# Create one at https://console.cloud.google.com/apis/credentials
# Share your Google Sheet with the service account email
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}
# Name of the Google Sheet to log leads
SHEET_NAME=Lead Qualification Log
